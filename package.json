  "scripts": {
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "dev": "cross-env NODE_ENV=development NODE_NO_WARNINGS=1 tsx watch --clear-screen=false server/index.ts",
    "migrate:aliases": "node scripts/convert-aliases.cjs",
    "migrate:notifications": "node --import tsx server/migrations/add-notification-enums-simple.ts",
    "migrate:attachments": "node --import tsx server/migrations/add-message-attachments.ts",
    "migrate:new-fields": "node --import tsx server/migrations/add-conversation-offer-company-fields.ts",
